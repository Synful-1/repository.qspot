<?xml version='1.0' encoding='utf-8'?>
<addons><addon id="plugin.program.qspotwizard" name="Q Spot Restore Wizard" version="1.0.0" provider-name="Techman">
    <requires>
        <import addon="xbmc.python" version="3.0.0" />
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>Custom Kodi Build Restore</summary>
        <description>Downloads and restores Kodi build from Dropbox link</description>
        <platform>all</platform>
 	<assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon><addon id="repository.qspot" name="Q Spot Repository" version="1.0.0" provider-name="TechmanQ">
    <extension point="xbmc.addon.repository" name="Q Spot Repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/Synful-1/repository.qspot/master/repo/zips/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/Synful-1/repository.qspot/master/repo/zips/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/Synful-1/repository.qspot/master/repo/zips/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>Kodi Repository</summary>
        <description>Techman's Repository for Custom Builds</description>
        <disclaimer />
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon></addons>